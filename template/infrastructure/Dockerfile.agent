# OperatorOS Agent Base Image
# Pre-installs OpenClaw so containers start faster (no npm install on boot).
#
# Build:  docker build -t operatoros/agent-base:latest -f template/infrastructure/Dockerfile.agent .
# Usage:  docker run -d -v /path/to/workspace:/workspace operatoros/agent-base:latest

FROM node:20-slim

# Install system deps first (git + ssh needed by openclaw's npm install for git deps)
RUN apt-get update && apt-get install -y --no-install-recommends git curl openssh-client && \
    rm -rf /var/lib/apt/lists/*

# Install OpenClaw CLI globally (pinned version for reproducibility)
RUN npm install -g openclaw@2026.3.13 && npm cache clean --force

WORKDIR /workspace

EXPOSE 3000

HEALTHCHECK --interval=60s --timeout=10s --start-period=30s --retries=3 \
  CMD openclaw status || exit 1

CMD ["openclaw", "gateway", "start", "--foreground"]
